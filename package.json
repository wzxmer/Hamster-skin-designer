{
  "name": "hamster3-skins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/workbench-server.mjs",
    "start": "node scripts/workbench-server.mjs",
    "validate:project-schema": "node packages/project-schema/validate-sample.js",
    "test:skin-effect": "node packages/skin-effect/test-skin-effect.js",
    "test:exporter": "node packages/exporter/test-exporter.js",
    "test:importer": "node packages/importer/test-importer.js",
    "test:preview": "node --check apps/workbench/src/ui/preview.js && node packages/preview-engine/test-preview-linkage.js",
    "build:import-test": "node scripts/generate-import-test-package.mjs",
    "bump:workbench-version": "node scripts/bump-workbench-version.mjs",
    "update:workbench-version": "node scripts/update-workbench-version.mjs",
    "build": "npm run validate:project-schema && npm run test:skin-effect && npm run test:exporter && npm run test:importer && npm run test:preview && node --check apps/workbench/src/app.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "3.4"
  }
}
